# ╔══════════════════════════════════════════════════════════════════╗
# ║   CourierX — Environment Configuration                          ║
# ║   Copy this file to .env and fill in your credentials.          ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Option 1: Local MySQL (default) ───────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_local_password
DB_NAME=Project
DB_SSL=false

# ── Option 2: TiDB Cloud (recommended FREE cloud option) ──────────
# Sign up free at: https://tidbcloud.com
# After creating a cluster, go to Connect → choose "General" driver
# and copy the fields below:
#
# DB_HOST=gateway01.ap-southeast-1.prod.tidbcloud.com
# DB_PORT=4000
# DB_USER=your_tidb_username.root
# DB_PASSWORD=your_tidb_password
# DB_NAME=Project
# DB_SSL=true

# ── Option 3: Aiven for MySQL ─────────────────────────────────────
# Sign up at: https://aiven.io (30-day free trial)
# After creating a MySQL service, copy from "Connection Information":
#
# DB_HOST=your-service.aivencloud.com
# DB_PORT=your_port
# DB_USER=avnadmin
# DB_PASSWORD=your_aiven_password
# DB_NAME=defaultdb
# DB_SSL=true

# ── Option 4: Railway MySQL ────────────────────────────────────────
# Create project at: https://railway.app → Add MySQL plugin
# Copy from the Variables tab:
#
# DB_HOST=containers-us-west-xxx.railway.app
# DB_PORT=6539
# DB_USER=root
# DB_PASSWORD=your_railway_password
# DB_NAME=railway
# DB_SSL=false
